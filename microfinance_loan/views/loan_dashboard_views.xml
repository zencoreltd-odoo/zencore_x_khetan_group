<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Loan Dashboard List View -->
    <record id="view_loan_dashboard_list" model="ir.ui.view">
        <field name="name">microfinance.loan.dashboard.list</field>
        <field name="model">microfinance.loan.dashboard</field>
        <field name="arch" type="xml">
            <list string="Loan Dashboard"
                  create="false"
                  edit="false"
                  delete="false"
                  open_form_view="false"
                  decoration-danger="loan_amount &lt; 0"
                  decoration-success="loan_amount == 0"
                  action="open_party_transactions"
                  type="object">

                <field name="customer_name" string="Customer Name"/>
                <field name="loan_amount"        string="Loan Amount"/>
                <field name="receive_amount"     string="Receive Amount"/>
                <field name="interest_rate"      string="Interest Rate (%)"/>
                <field name="interest_amount"    string="Interest Amount"/>
                <field name="interest_received"  string="Interest Received" optional="show"/>
                <field name="closing_balance"    string="Closing Balance"/>
                <field name="is_compound_interest" string="Compound" optional="show"/>
                <field name="loan_account_id"    optional="hide"/>
                <field name="loan_party_id"      column_invisible="1"/>

            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_loan_dashboard_search" model="ir.ui.view">
        <field name="name">microfinance.loan.dashboard.search</field>
        <field name="model">microfinance.loan.dashboard</field>
        <field name="arch" type="xml">
            <search string="Search Dashboard">
                <field name="customer_name"/>
                <filter string="Compound Interest"
                        name="compound"
                        domain="[('is_compound_interest','=',True)]"/>
                <filter string="Outstanding Loan"
                        name="outstanding"
                        domain="[('loan_amount','&gt;',0)]"/>
                <filter string="Accrued Interest"
                        name="has_interest"
                        domain="[('interest_amount','&gt;',0)]"/>
            </search>
        </field>
    </record>

    <!-- ACTION — clicking a row opens the Loan Party form on Transaction History tab -->
    <record id="action_loan_dashboard_window" model="ir.actions.act_window">
        <field name="name">Loan Dashboard</field>
        <field name="res_model">microfinance.loan.dashboard</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_loan_dashboard_list"/>
        <field name="search_view_id" ref="view_loan_dashboard_search"/>
        <field name="target">current</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No active loan parties yet.
            </p>
            <p>Create Loan Parties to see summary here.</p>
        </field>
    </record>

</odoo>
